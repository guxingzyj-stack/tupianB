# ===== 老照 后端环境变量 =====
# 复制为 .env 并填入真实值。绝不要把真实 .env 提交到 git。

# --- relay (国内 AI 中转站, OpenAI 兼容接口) ---
# RELAY_BASE_URL 填到 /v1 为止 (与 OpenAI SDK 的 base_url 习惯一致)
RELAY_BASE_URL=https://your-relay.example.com/v1
RELAY_API_KEY=sk-xxxxxxxxxxxxxxxx
# 看图分析主模型
RELAY_MODEL=claude-sonnet-4-6
# 备用模型 (主模型失败时尝试; 留空表示不启用备用, 直接退通用三选项)
RELAY_BACKUP_MODEL=

# --- 存储 ---
DB_PATH=./data/app.db
FILE_BASE=./data/files

# --- App 鉴权 (见架构 §5.2) ---
# App 内置的硬编码 token; 留空 = 关闭鉴权 (仅本地开发用, 线上必须设置)
APP_TOKEN=change-me-to-a-long-random-string

# --- 对外可访问的后端根地址, 用于拼接返回给客户端的图片/视频 URL ---
# 本地: http://localhost:8000   线上: https://xxx.zeabur.app
PUBLIC_BASE_URL=http://localhost:8000

# --- 调优 ---
CLAUDE_TIMEOUT=30
RATE_LIMIT_PER_MIN=60
WORKER_COUNT=2
